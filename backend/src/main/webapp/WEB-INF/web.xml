<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">
    
    <display-name>Optica Digital App</display-name>
    
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- CORS Filter -->
    <filter>
        <filter-name>CORSFilter</filter-name>
        <filter-class>com.opticadigital.filter.CORSFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>CORSFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Servlet Registration -->
    <servlet>
        <servlet-name>UsuarioServlet</servlet-name>
        <servlet-class>com.opticadigital.servlet.UsuarioServlet</servlet-class>
    </servlet>
    
    <servlet-mapping>
        <servlet-name>UsuarioServlet</servlet-name>
        <url-pattern>/usuarios</url-pattern>
    </servlet-mapping>

    <!-- API REST Servlet -->
    <servlet>
        <servlet-name>UsuarioApiServlet</servlet-name>
        <servlet-class>com.opticadigital.api.UsuarioApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UsuarioApiServlet</servlet-name>
        <url-pattern>/api/usuarios/*</url-pattern>
    </servlet-mapping>



    <!-- Configuración del DataSource JNDI -->
    <resource-ref>
        <description>MySQL DataSource para OpticaDigital</description>
        <res-ref-name>jdbc/opticadigitalDB</res-ref-name>
        <res-type>javax.sql.DataSource</res-type>
        <res-auth>Container</res-auth>
    </resource-ref>

</web-app>
